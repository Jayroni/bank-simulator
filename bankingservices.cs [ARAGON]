class BankingService
{
    private static double lastTransaction = 0;

    public static double CheckBalance(double balance) => balance;

    public static bool Deposit(ref double balance, double amount)
    {
        if (amount <= 0) return false;
        balance += amount;
        lastTransaction = amount;
        return true;
    }

    public static bool Withdraw(ref double balance, double amount)
    {
        if (amount <= 0 || balance < amount) return false;
        balance -= amount;
        lastTransaction = -amount;
        return true;
    }

    public static double GetLastTransaction() => lastTransaction;
}
