class BankingView
{
    public static void DisplayHeader() => Console.WriteLine("=== Simple ATM System ===");

    public static void DisplayInitialBalance(double balance) => Console.WriteLine($"Initial Balance: ₱{balance:F2}");

    public static void DisplayMenu()
    {
        Console.WriteLine("\nATM Menu:");
        Console.WriteLine("1: Check Balance");
        Console.WriteLine("2: Deposit Money");
        Console.WriteLine("3: Withdraw Money");
        Console.WriteLine("4: Print Mini Statement");
        Console.WriteLine("5: Exit");
        Console.Write("Select an option: ");
    }

    public static void DisplayBalance(double balance) => Console.WriteLine($"Current Balance: ₱{balance:F2}");

    public static double PromptAmount(string action)
    {
        Console.Write($"Enter amount to {action}: ");
        double amount;
        return double.TryParse(Console.ReadLine(), out amount) ? amount : -1; // -1 indicates invalid input
    }

    public static void DisplayTransactionResult(bool success, double balance, string action, string errorMessage)
    {
        if (success)
        {
            Console.WriteLine($"{action} successful.");
            Console.WriteLine($"Updated Balance: ₱{balance:F2}");
        }
        else
        {
            Console.WriteLine(errorMessage);
        }
    }

    public static void DisplayMiniStatement(double balance, double lastTransaction)
    {
        Console.WriteLine("--- Mini Statement ---");
        Console.WriteLine($"Current Balance: ₱{balance:F2}");
        Console.WriteLine($"Last Transaction Amount: ₱{lastTransaction:F2}");
    }

    public static void DisplayExit() => Console.WriteLine("Thank you for using the ATM. Goodbye!");

    public static void DisplayInvalidOption() => Console.WriteLine("Invalid option selected. Please try again.");
}

class BankingApp
{
    static void Main(string[] args)
    {
        double balance = 1000.00;
        BankingView.DisplayHeader();
        BankingView.DisplayInitialBalance(balance);

        while (true)
        {
            BankingView.DisplayMenu();
            string choice = Console.ReadLine();

            switch (choice)
            {
                case "1":
                    BankingView.DisplayBalance(BankingService.CheckBalance(balance));
                    break;
                case "2":
                    double depositAmount = BankingView.PromptAmount("deposit");
                    if (depositAmount > 0)
                    {
                        bool success = BankingService.Deposit(ref balance, depositAmount);
                        BankingView.DisplayTransactionResult(success, balance, "Deposit", "Invalid deposit amount. Please enter a positive value.");
                    }
                    else
                    {
                        BankingView.DisplayTransactionResult(false, balance, "Deposit", "Invalid deposit amount. Please enter a positive value.");
                    }
                    break;
                case "3":
                    double withdrawAmount = BankingView.PromptAmount("withdraw");
                    if (withdrawAmount > 0)
                    {
                        bool success = BankingService.Withdraw(ref balance, withdrawAmount);
                        string error = success ? "" : (balance >= withdrawAmount ? "Invalid withdrawal amount." : "Insufficient balance.");
                        BankingView.DisplayTransactionResult(success, balance, "Withdrawal", error);
                    }
                    else
                    {
                        BankingView.DisplayTransactionResult(false, balance, "Withdrawal", "Invalid withdrawal amount. Please enter a positive value.");
                    }
                    break;
                case "4":
                    BankingView.DisplayMiniStatement(balance, BankingService.GetLastTransaction());
                    break;
                case "5":
                    BankingView.DisplayExit();
                    return;
                default:
                    BankingView.DisplayInvalidOption();
                    break;
            }
        }
    }
}
